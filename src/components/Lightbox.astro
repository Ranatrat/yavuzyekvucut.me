---
<div id="lightbox" class="hidden fixed inset-0 z-[9999] bg-portfolio-vintage-bg light:bg-portfolio-white-bg justify-center items-center transition-colors duration-700">
  
  <span class="absolute top-8 right-10 md:right-16 text-5xl text-portfolio-vintage-text light:text-portfolio-white-text cursor-pointer font-thin hover:opacity-50 transition-opacity z-50" id="lightbox-close">&times;</span>
  
  <img id="lightbox-img" src="" class="max-w-[90vw] max-h-[85vh] object-contain shadow-2xl" alt="Fullscreen Image">
</div>

<script is:inline>
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img');
  const closeBtn = document.getElementById('lightbox-close');

  window.openLightbox = function(src) {
    lightboxImg.src = src;
    lightbox.classList.remove('hidden');
    lightbox.classList.add('flex');
    // Fotoğraf açıldığında arkadaki sitenin yukarı aşağı kaymasını (scroll) engelle
    document.body.style.overflow = 'hidden'; 
  }

  window.closeLightbox = function() {
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
    // Scroll'u geri aç
    document.body.style.overflow = 'auto'; 
  }

  closeBtn.addEventListener('click', closeLightbox);
  
  // Fotoğrafın dışındaki bir yere tıklanırsa da kapat
  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) {
      closeLightbox();
    }
  });
</script>---
