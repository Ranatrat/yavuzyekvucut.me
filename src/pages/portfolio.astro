---
import BaseLayout from '../layouts/BaseLayout.astro';

const PB_URL = 'http://100.71.10.116:8090'; 
const response = await fetch(`${PB_URL}/api/collections/site_settings/records`);
const data = await response.json();
const settings = data.items[0] || {}; 

function getImg(filename) {
  if (!filename) return 'https://images.unsplash.com/photo-1534528741775-53994a69daeb?auto=format&fit=crop&w=800';
  return `${PB_URL}/api/files/${settings.collectionId}/${settings.id}/${filename}`;
}
---

<BaseLayout title="Portfolio">
  <div class="text-center mb-24">
    <h2 class="font-normal text-xs tracking-[6px] uppercase mb-4 opacity-60">Selected Works</h2>
    <div class="w-12 h-px bg-portfolio-vintage-border light:bg-portfolio-white-border mx-auto"></div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-16 md:gap-24 max-w-5xl mx-auto">
    
    <a href="/portfolio/portraits" class="group relative block overflow-hidden aspect-[2/3] cursor-pointer">
      <img src={getImg(settings.cover_portraits)} alt="Portraits" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105" />
      <div class="absolute inset-0 bg-black/20 dark:bg-black/40 light:bg-white/10 group-hover:bg-black/60 transition-colors duration-500 flex items-center justify-center">
        <span class="text-white light:text-white font-normal tracking-[5px] uppercase text-xl">Portraits</span>
      </div>
    </a>

    <a href="/portfolio/landscapes" class="group relative block overflow-hidden aspect-[2/3] cursor-pointer md:mt-32">
      <img src={getImg(settings.cover_landscapes)} alt="Buildings" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105" />
      <div class="absolute inset-0 bg-black/20 dark:bg-black/40 light:bg-white/10 group-hover:bg-black/60 transition-colors duration-500 flex items-center justify-center text-center">
        <span class="text-white light:text-white font-normal tracking-[5px] uppercase text-xl px-4">Buildings &<br/>Landscapes</span>
      </div>
    </a>

  </div>
</BaseLayout>
