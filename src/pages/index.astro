---
import BaseLayout from '../layouts/BaseLayout.astro';

const PB_URL = 'https://api.yavuzyekvucut.me'; 

const response = await fetch(`${PB_URL}/api/collections/site_settings/records?sort=-created`);
const data = await response.json();
const settings = data.items[0] || {}; 

function getImg(filename) {
  if (!filename || filename.length === 0) {
    return 'https://images.unsplash.com/photo-1510215848574-8451121d5b35?auto=format&fit=crop&w=800'; 
  }
  const file = Array.isArray(filename) ? filename[0] : filename;
  return `${PB_URL}/api/files/${settings.collectionId}/${settings.id}/${file}`;
}
---

<BaseLayout title="Home">
  
  <div class="grid grid-cols-1 md:grid-cols-3 gap-20 mb-32">
    <img src={getImg(settings.vitrin_1)} alt="Vitrine 1" class="w-full aspect-[2/3] object-cover cursor-pointer hover:opacity-85 transition-opacity duration-500" onclick="openLightbox(this.src)" />
    <img src={getImg(settings.vitrin_2)} alt="Vitrine 2" class="w-full aspect-[2/3] object-cover cursor-pointer hover:opacity-85 transition-opacity duration-500" onclick="openLightbox(this.src)" />
    <img src={getImg(settings.vitrin_3)} alt="Vitrine 3" class="w-full aspect-[2/3] object-cover cursor-pointer hover:opacity-85 transition-opacity duration-500" onclick="openLightbox(this.src)" />
  </div>

  <div class="border-t border-portfolio-vintage-border light:border-portfolio-white-border my-24"></div>

  <div class="flex flex-col md:flex-row items-center gap-24 mb-32">
    <div class="flex-[0_0_35%] w-full">
      <img src={getImg(settings.bio_photo)} alt="Yavuz Yekvücut Portrait" class="w-full aspect-[3/4] object-cover" />
    </div>
    <div class="flex-1 text-center md:text-left">
      <h2 class="font-normal text-xs lg:text-sm tracking-[4px] uppercase mb-10">ABOUT ME</h2>
      <div class="text-lg lg:text-xl tracking-[0.5px] leading-relaxed space-y-4">
        <p>I am a storyteller working across photography and film. For me, the narrative comes first—the medium follows.</p>
        <p>My work moves through everyday spaces, quiet tensions, and the politics of what is seen and what remains unseen.</p>
      </div>
    </div>
  </div>

  <div class="border-t border-portfolio-vintage-border light:border-portfolio-white-border my-24"></div>

  <div class="text-center">
    <h3 class="font-normal text-xs lg:text-sm tracking-[5px] uppercase mb-16">MORE</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-16">
      
<a href="/portfolio" class="relative overflow-hidden aspect-[16/9] group block">
        <img src={getImg(settings.cover_portfolio)} alt="Portfolio Preview" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105" />
        <div class="absolute inset-0 bg-black/40 light:bg-white/30 group-hover:bg-black/60 transition-colors duration-500 flex items-center justify-center">
          <span class="text-white light:text-portfolio-white-text font-normal tracking-[4px] uppercase text-sm md:text-base">Portfolio</span>
        </div>
      </a>
      
      <a href="/about" class="relative overflow-hidden aspect-[16/9] group block">
        <img src={getImg(settings.cover_about)} alt="About Preview" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105" />
        <div class="absolute inset-0 bg-black/40 light:bg-white/30 group-hover:bg-black/60 transition-colors duration-500 flex items-center justify-center">
          <span class="text-white light:text-portfolio-white-text font-normal tracking-[4px] uppercase text-sm md:text-base">About</span>
        </div>
      </a>

      <a href="/contact" class="relative overflow-hidden aspect-[16/9] group block">
        <img src={getImg(settings.cover_contact)} alt="Contact Preview" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105" />
        <div class="absolute inset-0 bg-black/40 light:bg-white/30 group-hover:bg-black/60 transition-colors duration-500 flex items-center justify-center">
          <span class="text-white light:text-portfolio-white-text font-normal tracking-[4px] uppercase text-sm md:text-base">Contact</span>
        </div>
      </a>

    </div>
  </div>

</BaseLayout>
