---
import BaseLayout from '../../layouts/BaseLayout.astro';

const PB_URL = 'https://api.yavuzyekvucut.me'; 

// Kategori filtrelemesi 'landscapes' olarak ayarlandı
const response = await fetch(`${PB_URL}/api/collections/photos/records?filter=(category='landscapes')&sort=sort_order&perPage=100`);
const data = await response.json();
const photos = data.items || [];

// Fotoğrafları sol ve sağ sütun olarak ikiye ayırıyoruz
const leftColumn = photos.filter((_, index) => index % 2 === 0);
const rightColumn = photos.filter((_, index) => index % 2 === 1);
---

<BaseLayout title="Buildings & Landscapes">
  <div class="text-center mb-24">
    <h2 class="font-normal text-xs tracking-[6px] uppercase mb-4 opacity-60">Buildings & Landscapes</h2>
  </div>

  {photos.length === 0 ? (
    <p class="text-center opacity-50">Henüz fotoğraf yüklenmedi.</p>
  ) : (
    <div class="flex flex-col md:flex-row gap-x-16 md:gap-x-24 items-start max-w-7xl mx-auto">
      
      <div class="flex-1 flex flex-col gap-y-16 md:gap-y-32 w-full">
        {leftColumn.map((photo) => {
          const imageUrl = `${PB_URL}/api/files/${photo.collectionId}/${photo.id}/${photo.image}`;
          return (
            <img 
              src={imageUrl} 
              alt={photo.title || 'Landscape Photography'} 
              onclick="openLightbox(this.src)" 
              class="w-full h-auto cursor-pointer hover:opacity-90 transition-opacity duration-500" 
            />
          );
        })}
      </div>

      <div class="flex-1 flex flex-col gap-y-16 md:gap-y-32 w-full mt-16 md:mt-40">
        {rightColumn.map((photo) => {
          const imageUrl = `${PB_URL}/api/files/${photo.collectionId}/${photo.id}/${photo.image}`;
          return (
            <img 
              src={imageUrl} 
              alt={photo.title || 'Landscape Photography'} 
              onclick="openLightbox(this.src)" 
              class="w-full h-auto cursor-pointer hover:opacity-90 transition-opacity duration-500" 
            />
          );
        })}
      </div>

    </div>
  )}
</BaseLayout>
