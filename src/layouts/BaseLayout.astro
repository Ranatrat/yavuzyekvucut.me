---
// src/layouts/BaseLayout.astro
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Lightbox from '../components/Lightbox.astro';

const { title } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/logo.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | Yavuz Yekvücut</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500&display=swap" rel="stylesheet">

    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return 'vintage'; // Varsayılan karanlık/sunkissed tema
      })();
      if (theme === 'light') {
        document.documentElement.classList.add('light');
      } else {
        document.documentElement.classList.remove('light');
      }
    </script>
  </head>
  <body class="font-sans font-light bg-portfolio-vintage-bg text-portfolio-vintage-text light:bg-portfolio-white-bg light:text-portfolio-white-text transition-colors duration-700 ease-in-out">
    
    <Header />
    
    <div class="border-t border-portfolio-vintage-border light:border-portfolio-white-border max-w-[1400px] mx-auto w-[calc(100%-80px)] md:w-[calc(100%-160px)] mb-20"></div>

    <main class="max-w-[1400px] mx-auto px-10 md:px-20 pb-32 min-h-screen">
      <slot />
    </main>

    <Footer />
    <Lightbox />
  </body>
</html>
